{
  "type": "aws",
  "httpMethod": "POST",
  "uri": "${CREATE_BLOOD_DONATION_INVOCATION_ARN}",
  "responses": {
    "default": {
      "statusCode": "200",
      "responseParameters": {
        "method.response.header.Access-Control-Allow-Methods": "'POST'",
        "method.response.header.Access-Control-Allow-Headers": "'Content-Type,X-Amz-Date,Authorization,X-Api-Key,X-Amz-Security-Token'",
        "method.response.header.Access-Control-Allow-Origin": "'*'"
      }
    }
  },
  "requestTemplates": {
    "application/json": "#set($inputRoot = $input.path('$'))\n{\n  \"seekerId\": \"$inputRoot.seekerId\",\n  \"bloodGroup\": \"$inputRoot.bloodGroup\",\n  \"location\": \"$inputRoot.location\",\n  \"donationDateTime\": \"$inputRoot.donationDateTime\"\n}"
  },
  "passthroughBehavior": "never"
}